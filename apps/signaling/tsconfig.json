{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "NodeNext",
    "moduleResolution":  "NodeNext",
    "outDir":            "dist",
    "rootDir":           "src",
    "strict":            true,
    "esModuleInterop":   true,
    "skipLibCheck":      true,
    "paths": {
      "@nexus/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include":  ["src"],
  "exclude":  ["node_modules", "dist"]
}
