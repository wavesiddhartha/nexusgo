# ── NEXUS Web App ──────────────────────────────────────────────────────────────
# Copy to .env.local and fill in values

# WebSocket URL of your signaling server
NEXT_PUBLIC_SIGNALING_URL=ws://localhost:8787

# For production:
# NEXT_PUBLIC_SIGNALING_URL=wss://signal.nexusgo.me

# Public app URL (used in QR codes and push links)
NEXT_PUBLIC_APP_URL=https://nexusgo.me
